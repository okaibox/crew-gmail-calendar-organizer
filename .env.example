# Gmail 계정: config/accounts.json에서 관리
# 인증: python3 lib/google_api.py auth --account EMAIL

# 캘린더 ID: config/accounts.json에서 관리

# LLM 프로바이더 설정
# codex (기본값) - Codex CLI (npm install -g @openai/codex) 사용
# ollama - 로컬 Ollama 서버 사용
# LLM_PROVIDER=codex

# Ollama 설정 (LLM_PROVIDER=ollama)
# LLM_MODEL=phi4
# LLM_BASE_URL=http://localhost:11434

# Codex 설정 (LLM_PROVIDER=codex)
# CODEX_MODEL=
# CODEX_API_KEY= 또는 OPENAI_API_KEY=

# confidence 기준값 (0.0~1.0, 이 값 미만이면 피드백 큐로)
CONFIDENCE_THRESHOLD=0.6
